{
  "name": "bob-yaml-wizard",
  "version": "1.0.0",
  "description": "Visual CICS Configuration Builder with AI-Powered Assistance",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "keywords": [
    "cics",
    "zos",
    "mainframe",
    "configuration",
    "yaml",
    "ai",
    "visual-builder"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "js-yaml": "^4.1.0",
    "mermaid": "^10.6.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "eslint": "^8.55.0",
    "gh-pages": "^6.1.0",
    "prettier": "^3.1.1",
    "vite": "^5.0.8",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
